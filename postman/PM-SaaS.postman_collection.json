            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}", "host": ["{{baseUrl}}"], "path": ["projects", "{{projectId}}"] },
            "description": "ADMIN only."
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200 OK', function () { pm.response.to.have.status(200); });"] } }
          ]
        }
      ]
    },
    {
      "name": "04 - Tasks",
      "item": [
        {
          "name": "Create Task (unassigned)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Set up CI pipeline\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "tasks"]
            },
            "description": "ADMIN only."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created, version 0', function () {",
                  "  pm.response.to.have.status(201);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data.version).to.eql(0);",
                  "  pm.environment.set('taskId', json.data.id);",
                  "  pm.environment.set('taskVersion', json.data.version);",
                  "  pm.environment.set('adminTaskId', json.data.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Task (assigned to Member)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Write onboarding docs\",\n  \"assigneeId\": \"{{memberId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "tasks"]
            },
            "description": "ADMIN only. assigneeId set → enqueues a BullMQ 'notifications' job; check the server console for the mock-email log line. Captures memberTaskId for the RBAC demo folder."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', function () {",
                  "  pm.response.to.have.status(201);",
                  "  const json = pm.response.json();",
                  "  pm.environment.set('memberTaskId', json.data.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List Tasks",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "tasks"]
            },
            "description": "Any authenticated role. Includes assignee (id, name, email)."
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200 OK', function () { pm.response.to.have.status(200); });"] } }
          ]
        },
        {
          "name": "Get Task by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "tasks", "{{taskId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.environment.set('taskVersion', pm.response.json().data.version);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Task (optimistic lock OK)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Set up CI pipeline (in progress)\",\n  \"status\": \"DOING\",\n  \"version\": {{taskVersion}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "tasks", "{{taskId}}"]
            },
            "description": "Any authenticated role, but service-level rule: Member can only update a task assigned to themself, Admin can update any. Body must carry the current `version`; wrong/stale version → 409."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK, version incremented', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.environment.set('taskVersion', json.data.version);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Task (stale version → 409)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Racing update\",\n  \"version\": 0\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "tasks", "{{taskId}}"]
            },
            "description": "Deliberately reuses version 0, which is now stale after the previous request incremented it — demonstrates the optimistic-lock 409."
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('409 Conflict (stale version)', function () { pm.response.to.have.status(409); });"] } }
          ]
        }
      ]
    },
    {
      "name": "05 - RBAC demo (expect 403)",
      "item": [
        {
          "name": "Member: Create Project → 403",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{memberToken}}", "type": "string" }] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Should be blocked\"\n}" },
            "url": { "raw": "{{baseUrl}}/projects", "host": ["{{baseUrl}}"], "path": ["projects"] },
            "description": "Route-level RBAC (spec §6): only ADMIN can create projects."
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('403 Forbidden', function () { pm.response.to.have.status(403); });"] } }
          ]
        },
        {
          "name": "Member: Delete Project → 403",
          "request": {
            "method": "DELETE",
            "header": [],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{memberToken}}", "type": "string" }] },
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}", "host": ["{{baseUrl}}"], "path": ["projects", "{{projectId}}"] }
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('403 Forbidden', function () { pm.response.to.have.status(403); });"] } }
          ]
        },
        {
          "name": "Member: Update Admin's Task → 403",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{memberToken}}", "type": "string" }] },
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"hijacked\",\n  \"version\": 0\n}" },
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/tasks/{{adminTaskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "tasks", "{{adminTaskId}}"]
            },
            "description": "Data-level RBAC (spec §6): Member may only update a task assigned to themself. adminTaskId is not assigned to the Member → 403, even though the route has no @Roles guard."
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('403 Forbidden', function () { pm.response.to.have.status(403); });"] } }
          ]
        },
        {
          "name": "Member: Update Own Task → 200",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{memberToken}}", "type": "string" }] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"DONE\",\n  \"version\": 0\n}" },
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/tasks/{{memberTaskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "tasks", "{{memberTaskId}}"]
            },
            "description": "memberTaskId is assigned to the Member (created in 04 - Tasks → 'Create Task (assigned to Member)') → allowed."
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200 OK', function () { pm.response.to.have.status(200); });"] } }
          ]
        }
      ]
    },
    {
      "name": "06 - Tenant isolation demo (expect 404, never 403)",
      "item": [
        {
          "name": "Register Admin (Company B)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "noauth" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyName\": \"{{companyBName}}\",\n  \"name\": \"{{companyBAdminName}}\",\n  \"email\": \"{{companyBAdminEmail}}\",\n  \"password\": \"{{companyBAdminPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "description": "A completely separate tenant, used only to prove Company A can't reach its data."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', function () {",
                  "  pm.response.to.have.status(201);",
                  "  pm.environment.set('companyBToken', pm.response.json().data.accessToken);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Company B: Create Project",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{companyBToken}}", "type": "string" }] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Globex Secret Project\"\n}" },
            "url": { "raw": "{{baseUrl}}/projects", "host": ["{{baseUrl}}"], "path": ["projects"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', function () {",
                  "  pm.response.to.have.status(201);",
                  "  pm.environment.set('projectBId', pm.response.json().data.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Company A: GET Company B's project → 404",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/projects/{{projectBId}}", "host": ["{{baseUrl}}"], "path": ["projects", "{{projectBId}}"] },
            "description": "Uses the default collection auth (adminToken = Company A). Guessing Company B's real project ID must 404, never 403 (spec §4.3) — 403 would leak that the ID is real."
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('404 Not Found', function () { pm.response.to.have.status(404); });"] } }
          ]
        },
        {
          "name": "Company A: PATCH Company B's project → 404",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Hijacked\"\n}" },
            "url": { "raw": "{{baseUrl}}/projects/{{projectBId}}", "host": ["{{baseUrl}}"], "path": ["projects", "{{projectBId}}"] }
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('404 Not Found', function () { pm.response.to.have.status(404); });"] } }
          ]
        },
        {
          "name": "Company A: DELETE Company B's project → 404",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/projects/{{projectBId}}", "host": ["{{baseUrl}}"], "path": ["projects", "{{projectBId}}"] }
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('404 Not Found', function () { pm.response.to.have.status(404); });"] } }
          ]
        },
        {
          "name": "Company A: List Projects excludes Company B",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/projects", "host": ["{{baseUrl}}"], "path": ["projects"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK and Globex project is absent', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const names = pm.response.json().data.map(p => p.name);",
                  "  pm.expect(names).to.not.include('Globex Secret Project');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "07 - Validation demo (expect 400)",
      "item": [
        {
          "name": "Register with empty body → 400",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "noauth" },
            "body": { "mode": "raw", "raw": "{}" },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('400 Bad Request', function () { pm.response.to.have.status(400); });"] } }
          ]
        },
        {
          "name": "Create project with injected companyId → 400",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nice try\",\n  \"companyId\": \"11111111-1111-1111-1111-111111111111\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/projects", "host": ["{{baseUrl}}"], "path": ["projects"] },
            "description": "Whitelist validation (ValidationPipe forbidNonWhitelisted) rejects any unknown field — proves tenant can't be smuggled in via body."
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('400 Bad Request', function () { pm.response.to.have.status(400); });"] } }
          ]
        }
      ]
    },
    {
      "name": "08 - Cleanup (run last, or standalone)",
      "item": [
        {
          "name": "Delete Task",
          "request": {
