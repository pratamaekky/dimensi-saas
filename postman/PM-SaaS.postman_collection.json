{
  "info": {
    "_postman_id": "5b5fd00a-9d08-4131-8e6c-67590d1cf963",
    "name": "PM SaaS (Multi-Tenant)",
    "description": "Mini Project Management SaaS API — auth, projects, tasks, users, plus a demo folder that proves tenant isolation (404, never 403) and RBAC (403 for Member on admin-only/other's-task actions). Run folders top to bottom with the paired environment; each request's Tests script auto-captures tokens/ids into environment variables for the next request.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "01 - Auth",
      "item": [
        {
          "name": "Register Admin (Company A)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "noauth" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyName\": \"{{companyName}}\",\n  \"name\": \"{{adminName}}\",\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "description": "Creates a new Company + an ADMIN user for it in one transaction, and returns a JWT (auto-login)."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Generate a fresh, run-unique suffix for every email used in this run.",
                  "// Why: email is unique per-company, not globally (spec §8.1) — login does a",
                  "// bare findFirst({ where: { email } }) and returns whichever company's user",
                  "// matches first. Re-running this collection with fixed emails would make",
                  "// 'Login Admin'/'Login Member' resolve to an OLD company from a previous run",
                  "// instead of the one just registered, breaking every request after it.",
                  "const suffix = `${Date.now()}-${Math.floor(Math.random() * 1e6)}`;",
                  "pm.environment.set('adminEmail', `alice.admin.${suffix}@acme.test`);",
                  "pm.environment.set('memberEmail', `bob.member.${suffix}@acme.test`);",
                  "pm.environment.set('companyBAdminEmail', `gina.admin.${suffix}@globex.test`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created with accessToken', function () {",
                  "  pm.response.to.have.status(201);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.data.accessToken).to.be.a('string');",
                  "  pm.environment.set('adminToken', json.data.accessToken);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "noauth" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "description": "Use this to re-obtain a token if adminToken expires, without re-registering."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 with accessToken', function () {",
                  "  pm.response.to.have.status(201);",
                  "  const json = pm.response.json();",
                  "  pm.environment.set('adminToken', json.data.accessToken);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 - Users (Admin only)",
      "item": [
        {
          "name": "Create Member",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{memberName}}\",\n  \"email\": \"{{memberEmail}}\",\n  \"password\": \"{{memberPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] },
            "description": "ADMIN only. Creates a MEMBER user in the caller's own company."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', function () {",
                  "  pm.response.to.have.status(201);",
                  "  const json = pm.response.json();",
                  "  pm.environment.set('memberId', json.data.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] },
            "description": "ADMIN only. Lists users scoped to the caller's own company."
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('200 OK', function () { pm.response.to.have.status(200); });"] }
            }
          ]
        },
        {
          "name": "Login Member",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "noauth" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{memberEmail}}\",\n  \"password\": \"{{memberPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "description": "Logs in as the Member created above; captures memberToken for the RBAC demo folder."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 with accessToken', function () {",
                  "  pm.response.to.have.status(201);",
                  "  const json = pm.response.json();",
                  "  pm.environment.set('memberToken', json.data.accessToken);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03 - Projects",
